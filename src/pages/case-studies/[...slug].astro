---
import Layout from "../../layouts/Layout.astro";
import HeroBackground from "../../components/HeroBackground.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const cases = await getCollection("case-studies", ({ data }) => !data.draft);
  return cases.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const services = (await getCollection("services", ({ data }) => !data.draft))
  .filter((s) => entry.data.services.includes(s.id))
  .sort((a, b) => a.data.order - b.data.order);

const otherCases = (await getCollection("case-studies", ({ data }) => !data.draft))
  .filter((c) => c.id !== entry.id)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title={`${entry.data.title} — CompTech Lab`}
  description={entry.data.summary}
  type="article"
>
  <section class="hero">
    <HeroBackground variant="default" />
    <div class="container">
      <span class="hero-eyebrow">{entry.data.sector ?? entry.data.customer}</span>
      <h1 class="hero-title">{entry.data.title}</h1>
      <p class="hero-lede">{entry.data.summary}</p>
      {entry.data.outcome && (
        <p style="margin-top: 1rem;">
          <span class="pill pill-accent">→ {entry.data.outcome}</span>
        </p>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <article class="prose">
        <Content />
      </article>

      {entry.data.technologies.length > 0 && (
        <div style="margin-top: 3rem;">
          <h2 class="section-title" style="font-size: 1.3rem;">Technologies on this engagement</h2>
          <div class="pill-row">
            {entry.data.technologies.map((t) => (
              <span class="pill">{t}</span>
            ))}
          </div>
        </div>
      )}

      {services.length > 0 && (
        <div style="margin-top: 3rem;">
          <h2 class="section-title" style="font-size: 1.3rem;">Related services</h2>
          <div class="card-grid card-grid-3">
            {services.map((s) => (
              <a href={`/services/${s.id}/`} class="card">
                <p class="card-eyebrow">{s.data.eyebrow ?? "Service"}</p>
                <h3 class="card-title">{s.data.title}</h3>
                <p class="card-desc">{s.data.tagline}</p>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <section class="section" style="background: var(--color-surface); border-top: 1px solid var(--color-border);">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Other case studies</span>
        <h2 class="section-title">More from the lab</h2>
      </div>
      <div class="card-grid card-grid-3">
        {otherCases.map((c) => (
          <a href={`/case-studies/${c.id}/`} class="card">
            <p class="card-eyebrow">{c.data.sector ?? c.data.customer}</p>
            <h3 class="card-title">{c.data.title}</h3>
            <p class="card-desc">{c.data.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
