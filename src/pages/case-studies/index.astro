---
import Layout from "../../layouts/Layout.astro";
import HeroBackground from "../../components/HeroBackground.astro";
import { getCollection } from "astro:content";

const cases = (await getCollection("case-studies", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Layout
  title="Engagement profiles — CompTech Lab"
  description="Representative engagement profiles from our practice — banking, insurance, telecom, public sector. Anonymised for client confidentiality."
>
  <section class="hero">
    <HeroBackground variant="default" />
    <div class="container">
      <span class="hero-eyebrow">Engagement profiles</span>
      <h1 class="hero-title">Representative engagements from our practice.</h1>
      <p class="hero-lede">
        Anonymised for client confidentiality. Each profile describes the shape of the
        engagement, the technologies involved, the approach, and the outcome delivered.
        Names and identifying details have been removed.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p style="background: var(--color-surface); border: 1px solid var(--color-border); border-left: 3px solid var(--color-accent); border-radius: 0.4rem; padding: 1rem 1.25rem; font-size: 0.92rem; color: var(--color-muted); margin: 0 0 2.5rem;">
        <strong style="color: var(--color-ink);">A note on confidentiality:</strong>
        client names, sites, and identifying details are not published. Profiles below are
        representative of the engagement type, with figures and identifiers omitted or
        generalised. References available under NDA.
      </p>

      <div class="card-grid">
        {cases.map((c) => (
          <a href={`/case-studies/${c.id}/`} class="card">
            <p class="card-eyebrow">{c.data.sector ?? c.data.customer}</p>
            <h2 class="card-title">{c.data.title}</h2>
            <p class="card-desc">{c.data.summary}</p>
            {c.data.outcome && <p class="card-meta">→ {c.data.outcome}</p>}
            {c.data.technologies.length > 0 && (
              <div class="pill-row" style="margin-top: 1rem;">
                {c.data.technologies.slice(0, 5).map((t) => (
                  <span class="pill">{t}</span>
                ))}
                {c.data.technologies.length > 5 && (
                  <span class="pill" style="opacity: 0.6;">+{c.data.technologies.length - 5}</span>
                )}
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
