---
import Layout from "../../layouts/Layout.astro";
import InteractiveDiagram from "../../components/InteractiveDiagram";

const tool = {
  background: "#ffffff",
  border: "1.5px solid #9ca3af",
  borderRadius: 6,
  padding: 8,
  color: "#1f2937",
  width: 150,
  textAlign: "center" as const,
  fontSize: 12,
};

const header = {
  background: "#161616",
  border: "1.5px solid #0f62fe",
  borderRadius: 8,
  padding: 12,
  color: "#ffffff",
  width: 240,
  textAlign: "center" as const,
  fontWeight: 700,
  fontSize: 13,
  letterSpacing: "0.04em",
  textTransform: "uppercase" as const,
};

const hub = {
  ...header,
  background: "#0f62fe",
  border: "2px solid #0043ce",
  width: 220,
  fontSize: 14,
};

const slug = (s: string) =>
  s.toLowerCase().replace(/[^a-z0-9]+/g, "_").replace(/^_|_$/g, "");

function cluster(label: string, baseX: number, baseY: number, tools: string[]) {
  const headerId = slug(label);
  const nodes: any[] = [
    { id: headerId, position: { x: baseX, y: baseY }, data: { label }, style: header },
  ];
  const edges: any[] = [];
  tools.forEach((t, i) => {
    const col = i % 2;
    const row = Math.floor(i / 2);
    const id = `${headerId}__${slug(t)}`;
    nodes.push({
      id,
      position: { x: baseX + (col === 0 ? -90 : 90), y: baseY + 80 + row * 48 },
      data: { label: t },
      style: tool,
    });
    edges.push({
      id: `${headerId}-${id}`,
      source: headerId,
      target: id,
      animated: false,
      style: { stroke: "#9ca3af", strokeWidth: 1 },
    });
  });
  return { nodes, edges };
}

const cloud = cluster("Cloud Platforms", 200, 100, [
  "OpenShift",
  "ACM",
  "OpenShift GitOps",
  "Terraform",
  "AWS",
  "Azure",
  "GCP",
  "ESO",
  "cert-manager",
  "LVMS",
  "oc-mirror",
  "Quay",
]);

const modernization = cluster("Application Modernization", 900, 100, [
  "OpenShift AI",
  "NVIDIA NIM",
  "vLLM",
  "Triton",
  "MCP",
  "LangChain",
  "Kubeflow",
  "WSO2 APIM",
  "WSO2 MI",
  "MuleSoft",
  "Camunda",
  "Temporal",
  "Apache Kafka",
  "Apache Spark",
  "JBoss EAP",
]);

const security = cluster("End-to-End Security", 200, 900, [
  "RHACS",
  "WSO2 IS",
  "Ping Identity",
  "Keycloak",
  "Vault",
  "Acunetix",
  "Invicti",
  "cosign",
  "SBOMs",
  "OPA",
]);

const ops = cluster("Operations", 900, 900, [
  "Datadog",
  "Grafana",
  "Prometheus",
  "OpenTelemetry",
  "Kiali",
  "Istio",
  "GitLab",
  "Nexus",
  "OADP",
  "Velero",
]);

const hubNode = {
  id: "comptech_lab",
  position: { x: 550, y: 500 },
  data: { label: "CompTech Lab Practice" },
  style: hub,
};

const hubEdges = [
  { id: "h-c", source: "comptech_lab", target: "cloud_platforms", animated: true, style: { stroke: "#0f62fe", strokeWidth: 2 }, markerEnd: { type: "arrowclosed", color: "#0f62fe" } },
  { id: "h-m", source: "comptech_lab", target: "application_modernization", animated: true, style: { stroke: "#0f62fe", strokeWidth: 2 }, markerEnd: { type: "arrowclosed", color: "#0f62fe" } },
  { id: "h-s", source: "comptech_lab", target: "end_to_end_security", animated: true, style: { stroke: "#0f62fe", strokeWidth: 2 }, markerEnd: { type: "arrowclosed", color: "#0f62fe" } },
  { id: "h-o", source: "comptech_lab", target: "operations", animated: true, style: { stroke: "#0f62fe", strokeWidth: 2 }, markerEnd: { type: "arrowclosed", color: "#0f62fe" } },
];

const nodes = [
  hubNode,
  ...cloud.nodes,
  ...modernization.nodes,
  ...security.nodes,
  ...ops.nodes,
];

const edges = [
  ...hubEdges,
  ...cloud.edges,
  ...modernization.edges,
  ...security.edges,
  ...ops.edges,
];
---

<Layout
  title="Capabilities — CompTech Lab"
  description="An interactive map of the technologies CompTech Lab operates across cloud platforms, application modernization, security, and operations."
>
  <section class="hero">
    <div class="container">
      <span class="hero-eyebrow">Capabilities</span>
      <h1 class="hero-title">The technology stack we deliver.</h1>
      <p class="hero-lede">
        An interactive map of the components we design, deploy, and operate &mdash; grouped by
        practice area. Drag to rearrange, click to highlight, expand to fullscreen.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <InteractiveDiagram client:load nodes={nodes} edges={edges} height={720} />

      <div class="card-grid card-grid-4" style="margin-top: 2.5rem;">
        <a href="/services/cloud-platforms/" class="card">
          <p class="card-eyebrow">Platforms</p>
          <h3 class="card-title">Cloud platforms</h3>
          <p class="card-desc">OpenShift, AWS, Azure, GCP, hybrid topologies, GitOps fleet.</p>
        </a>
        <a href="/services/application-modernization/" class="card">
          <p class="card-eyebrow">Modernization</p>
          <h3 class="card-title">Application modernization</h3>
          <p class="card-desc">Containerise, refactor, integrate, rebuild with AI where it earns its keep.</p>
        </a>
        <a href="/services/end-to-end-security/" class="card">
          <p class="card-eyebrow">Security</p>
          <h3 class="card-title">End-to-end security</h3>
          <p class="card-desc">Shift-left, shift-right, identity boundary, supply chain.</p>
        </a>
        <a href="/services/operations/" class="card">
          <p class="card-eyebrow">Operations</p>
          <h3 class="card-title">Operations &amp; managed services</h3>
          <p class="card-desc">Day-2, observability, SRE practice, bounded managed services.</p>
        </a>
      </div>
    </div>
  </section>
</Layout>
