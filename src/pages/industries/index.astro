---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const industries = (await getCollection("industries", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Layout
  title="Industries — CompTech Lab"
  description="Banking & financial services, insurance, telecom, public sector — regulated industries where platform discipline matters."
>
  <section class="hero">
    <div class="container">
      <span class="hero-eyebrow">Industries</span>
      <h1 class="hero-title">Built for regulated industries.</h1>
      <p class="hero-lede">
        We engage where platform discipline, security posture, and audit-grade engineering are
        non-negotiable — banking, insurance, telecom, and public sector. Each industry shapes
        the platforms we build for it.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card-grid">
        {industries.map((i) => (
          <a href={`/industries/${i.id}/`} class="card">
            <p class="card-eyebrow">{i.data.eyebrow ?? "Sector"}</p>
            <h2 class="card-title">{i.data.title}</h2>
            <p class="card-desc">{i.data.tagline}</p>
            {i.data.typical_workloads.length > 0 && (
              <div class="pill-row" style="margin-top: 1rem;">
                {i.data.typical_workloads.slice(0, 4).map((w) => (
                  <span class="pill">{w}</span>
                ))}
                {i.data.typical_workloads.length > 4 && (
                  <span class="pill" style="opacity: 0.6;">+{i.data.typical_workloads.length - 4}</span>
                )}
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
