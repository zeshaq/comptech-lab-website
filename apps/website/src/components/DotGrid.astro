---
/**
 * IBM-style decorative dot-grid pattern.
 * Used as background decoration in hero sections.
 */
interface Props {
  class?: string;
  color?: string;
  cols?: number;
  rows?: number;
  spacing?: number;
}

const {
  class: cls = "",
  color = "currentColor",
  cols = 12,
  rows = 6,
  spacing = 14,
} = Astro.props;

const dots = [];
for (let r = 0; r < rows; r++) {
  for (let c = 0; c < cols; c++) {
    dots.push({ x: c * spacing, y: r * spacing });
  }
}
const w = (cols - 1) * spacing + 4;
const h = (rows - 1) * spacing + 4;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={`0 0 ${w} ${h}`}
  width={w}
  height={h}
  class={cls}
  aria-hidden="true"
>
  {dots.map((d) => (
    <circle cx={d.x + 2} cy={d.y + 2} r="1.5" fill={color} />
  ))}
</svg>
