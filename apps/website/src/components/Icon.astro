---

{path && (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 32 32"
    width={size}
    height={size}
    fill={fill}
    stroke={strokeColor}
    stroke-width={sw}
    class={cls}
    aria-hidden="true"
    set:html={path}
  />
)}
