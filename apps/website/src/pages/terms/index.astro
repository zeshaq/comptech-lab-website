---
import Layout from "../../layouts/Layout.astro";
import HeroBackground from "../../components/HeroBackground.astro";

const effective = "2026-05-19";
---

<Layout
  title="Terms of use — CompTech"
  description="Terms of use for www.comptech-lab.com."
>
  <section class="hero">
    <HeroBackground variant="frames" />
    <div class="container">
      <span class="hero-eyebrow">Legal</span>
      <h1 class="hero-title">Terms of use.</h1>
      <p class="hero-lede">Effective {effective}.</p>
