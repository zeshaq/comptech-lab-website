---
import Layout from "../../layouts/Layout.astro";
import HeroBackground from "../../components/HeroBackground.astro";
---

<Layout
  title="Contact — CompTech"
  description="Tell us what you're building. We'll write back with a concrete scope and a path to ship."
>
  <section class="hero">
    <HeroBackground variant="orbits" />
    <div class="container">
      <span class="hero-eyebrow">Contact</span>
      <h1 class="hero-title">Tell us what you&rsquo;re building.</h1>
      <p class="hero-lede">
        Every message receives a personal reply. Substantive enquiries come back with a
        concrete first-two-weeks scope and a definition of done for the engagement.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="display: grid; gap: 3rem; grid-template-columns: 1fr;">

      <div style="display: grid; gap: 2rem; grid-template-columns: 1fr;" class="contact-offices">
        <div>
          <p class="section-eyebrow">Corporate office</p>
          <h3 style="font-size: 1.15rem; font-weight: 600; margin: 0.4rem 0 0.85rem;">Gulshan, Dhaka</h3>
          <address style="font-style: normal; line-height: 1.65; font-size: 0.95rem; color: var(--color-muted);">
            Richmond Concord, Level 7<br/>
            68 Gulshan Avenue<br/>
            Dhaka 1212, Bangladesh<br/>
            <br/>
            <a href="tel:+8801916277170" style="color: var(--color-accent);">+88 01916-277170</a><br/>
            <a href="tel:+8801958501206" style="color: var(--color-accent);">+88 01958-501206</a><br/>
            <a href="mailto:info@comptech.com.bd" style="color: var(--color-accent);">info@comptech.com.bd</a>
          </address>
        </div>
        <div>
          <p class="section-eyebrow">Head office</p>
          <h3 style="font-size: 1.15rem; font-weight: 600; margin: 0.4rem 0 0.85rem;">Uttara, Dhaka — Pinaki Group</h3>
          <address style="font-style: normal; line-height: 1.65; font-size: 0.95rem; color: var(--color-muted);">
            Pinaki Group<br/>
            29 Gareb-Newaz Avenue, Sector 11<br/>
            Uttara, Dhaka 1230, Bangladesh<br/>
            <br/>
            <a href="tel:+88028931996" style="color: var(--color-accent);">+88-02-8931996</a><br/>
            <a href="mailto:info@pinakigroup.com" style="color: var(--color-accent);">info@pinakigroup.com</a>
          </address>
        </div>
      </div>

      <div style="max-width: 720px; width: 100%;">
        <p class="section-eyebrow" style="margin-bottom: 0.5rem;">Send us a note</p>
        <h2 style="font-size: 1.5rem; font-weight: 400; margin: 0 0 1.5rem; letter-spacing: -0.01em;">For new engagements, partnership enquiries, or anything else</h2>
        <form id="contact-form" class="contact-form" method="POST" action="/api/contact">
        <div class="form-row">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" required autocomplete="name" />
        </div>

        <div class="form-row">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>

        <div class="form-row">
          <label for="company">Company</label>
          <input id="company" name="company" type="text" autocomplete="organization" />
        </div>

        <div class="form-row">
          <label for="service">What you need help with</label>
          <select id="service" name="service">
            <option value="">— select —</option>
            <option value="cloud-platforms">Cloud platforms (OpenShift, AWS, Azure, GCP)</option>
            <option value="security">Security practice</option>
            <option value="ai">AI practice</option>
            <option value="data">Data &amp; analytics practice</option>
            <option value="app-modernization">Application modernization</option>
            <option value="operations">Operations &amp; managed services</option>
            <option value="other">Something else / not sure</option>
          </select>
        </div>

        <div class="form-row">
          <label for="message">Tell us about the project</label>
          <textarea id="message" name="message" rows="6" required></textarea>
        </div>

        <input type="text" name="company_url" tabindex="-1" autocomplete="off" style="position: absolute; left: -9999px;" aria-hidden="true" />

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Send</button>
          <span id="form-status" class="form-status" aria-live="polite"></span>
        </div>

        <p class="form-fineprint">
          Or email <a href="mailto:info@comptech.com.bd" style="color: var(--color-accent);">info@comptech.com.bd</a> directly.
        </p>
      </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-row label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .form-row input,
  .form-row select,
  .form-row textarea {
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
    background: var(--color-canvas);
    color: var(--color-ink);
    font-family: inherit;
    font-size: 0.95rem;
    resize: vertical;
  }

  .form-row input:focus,
  .form-row select:focus,
  .form-row textarea:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -1px;
    border-color: var(--color-accent);
  }

  .form-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .form-status {
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .form-status[data-state="ok"] { color: var(--color-accent); }
  .form-status[data-state="err"] { color: #b91c1c; }

  .form-fineprint {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin: 0.5rem 0 0;
  }
</style>

<script is:inline>
  const form = document.getElementById("contact-form");
  const status = document.getElementById("form-status");
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      status.textContent = "Sending…";
      status.removeAttribute("data-state");

      const data = Object.fromEntries(new FormData(form).entries());
      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        if (res.ok) {
          status.textContent = "Sent. We'll get back to you shortly.";
          status.setAttribute("data-state", "ok");
          form.reset();
        } else {
          const body = await res.json().catch(() => ({}));
          status.textContent = body.error || "Could not send. Please email info@comptech.com.bd.";
          status.setAttribute("data-state", "err");
        }
      } catch (err) {
        status.textContent = "Could not send. Please email info@comptech.com.bd.";
        status.setAttribute("data-state", "err");
      }
    });
  }
</script>
