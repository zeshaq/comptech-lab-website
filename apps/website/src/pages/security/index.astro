<script is:inline>
  (() => {
    const root = document.querySelector("[data-tabs]");
    if (!root) return;
    const buttons = Array.from(root.querySelectorAll("[data-tab-target]"));
    const panels = Array.from(root.querySelectorAll(".tab-panel"));

    function activate(id, opts = {}) {
      buttons.forEach((b) => {
        const active = b.dataset.tabTarget === id;
        b.setAttribute("aria-selected", active ? "true" : "false");
        b.setAttribute("tabindex", active ? "0" : "-1");
      });
      panels.forEach((p) => {
        const active = p.id === `panel-${id}`;
        p.classList.toggle("is-active", active);
        if (active) p.removeAttribute("hidden");
        else p.setAttribute("hidden", "");
      });
      if (opts.updateHash) {
        history.replaceState(null, "", `#${id}`);
      }
      if (opts.focus) {
        const btn = buttons.find((b) => b.dataset.tabTarget === id);
        btn && btn.focus();
      }
    }

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => activate(btn.dataset.tabTarget, { updateHash: true }));
    });

    root.addEventListener("keydown", (e) => {
      if (!["ArrowLeft", "ArrowRight", "Home", "End"].includes(e.key)) return;
      const current = document.activeElement;
      const idx = buttons.indexOf(current);
      if (idx === -1) return;
      e.preventDefault();
      let nextIdx = idx;
      if (e.key === "ArrowLeft")  nextIdx = (idx - 1 + buttons.length) % buttons.length;
      if (e.key === "ArrowRight") nextIdx = (idx + 1) % buttons.length;
      if (e.key === "Home")       nextIdx = 0;
      if (e.key === "End")        nextIdx = buttons.length - 1;
      activate(buttons[nextIdx].dataset.tabTarget, { updateHash: true, focus: true });
    });

    const initial = (location.hash || "").replace(/^#/, "");
    if (initial && buttons.some((b) => b.dataset.tabTarget === initial)) {
      activate(initial);
    }
  })();
</script>
