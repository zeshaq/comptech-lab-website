---
import Layout from "../../layouts/Layout.astro";
import HeroBackground from "../../components/HeroBackground.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const services = await getCollection("services", ({ data }) => !data.draft);
  return services.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allServices = (await getCollection("services", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);

const related = (await getCollection("case-studies", ({ data }) => !data.draft))
  .filter((c) => entry.data.related_case_studies.includes(c.id))
  .sort((a, b) => a.data.order - b.data.order);

const otherServices = allServices.filter((s) => s.id !== entry.id);
---

<Layout title={`${entry.data.title} — CompTech Lab`} description={entry.data.description}>
  <section class="hero">
    <HeroBackground variant="cubes" />
    <div class="container">
      <span class="hero-eyebrow">{entry.data.eyebrow ?? "Service"}</span>
      <h1 class="hero-title">{entry.data.title}</h1>
      <p class="hero-lede">{entry.data.tagline}</p>
      <div class="hero-actions">
        <a href="/contact/" class="btn btn-primary">Start a project</a>
        <a href="/case-studies/" class="btn btn-secondary">See related work</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="display: grid; grid-template-columns: minmax(0, 1fr); gap: 3rem;">
      <article class="prose">
        <Content />
      </article>

      {entry.data.capabilities.length > 0 && (
        <aside>
          <h2 class="section-title" style="font-size: 1.4rem;">Capabilities</h2>
          <ul class="footer-list">
            {entry.data.capabilities.map((c) => (
              <li>{c}</li>
            ))}
          </ul>
        </aside>
      )}

      {entry.data.technologies.length > 0 && (
        <aside>
          <h2 class="section-title" style="font-size: 1.4rem;">Technologies we operate</h2>
          <div class="pill-row">
            {entry.data.technologies.map((t) => (
              <span class="pill">{t}</span>
            ))}
          </div>
        </aside>
      )}

      {related.length > 0 && (
        <aside>
          <h2 class="section-title" style="font-size: 1.4rem;">Related case studies</h2>
          <div class="card-grid">
            {related.map((c) => (
              <a href={`/case-studies/${c.id}/`} class="card">
                <p class="card-eyebrow">{c.data.sector ?? c.data.customer}</p>
                <h3 class="card-title">{c.data.title}</h3>
                <p class="card-desc">{c.data.summary}</p>
              </a>
            ))}
          </div>
        </aside>
      )}
    </div>
  </section>

  <section class="section" style="background: var(--color-surface); border-top: 1px solid var(--color-border);">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Other services</span>
        <h2 class="section-title">Where this fits in our practice</h2>
      </div>
      <div class="card-grid card-grid-3">
        {otherServices.map((s) => (
          <a href={`/services/${s.id}/`} class="card">
            <p class="card-eyebrow">{s.data.eyebrow ?? "Service"}</p>
            <h3 class="card-title">{s.data.title}</h3>
            <p class="card-desc">{s.data.tagline}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
