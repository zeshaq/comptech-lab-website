---
import Layout from "../../layouts/Layout.astro";
import Icon from "../../components/Icon.astro";
import DotGrid from "../../components/DotGrid.astro";
import HeroBackground from "../../components/HeroBackground.astro";
import { getCollection } from "astro:content";
import { SERVICE_ICONS } from "../../utils/icons";

const services = (await getCollection("services", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Layout
  title="Services — CompTech"
  description="OpenShift platform engineering, AI/ML enablement, DevSecOps & identity, integration & data."
>
  <section class="hero">
    <HeroBackground variant="cubes" />
    <div class="container">
      <span class="hero-eyebrow">Services</span>
      <h1 class="hero-title">Four practice areas. One delivery discipline.</h1>
      <p class="hero-lede">
        We engage where engineering depth, audit-grade discipline, and a documented handover
        matter. Each service is scoped against a documented outcome.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card-grid card-grid-2">
        {services.map((s) => (
          <a href={`/services/${s.id}/`} class="card">
            <div class="card-icon"><Icon name={SERVICE_ICONS[s.id] ?? "cloud"} size={32} /></div>
            <p class="card-eyebrow">{s.data.eyebrow ?? "Service"}</p>
            <h2 class="card-title">{s.data.title}</h2>
            <p class="card-desc">{s.data.tagline}</p>
            {s.data.technologies.length > 0 && (
              <div class="pill-row" style="margin-top: 1rem;">
                {s.data.technologies.slice(0, 6).map((t) => (
                  <span class="pill">{t}</span>
                ))}
                {s.data.technologies.length > 6 && (
                  <span class="pill" style="opacity: 0.6;">+{s.data.technologies.length - 6} more</span>
                )}
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
