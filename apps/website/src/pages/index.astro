---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/Icon.astro";
import DotGrid from "../components/DotGrid.astro";
import HeroBackground from "../components/HeroBackground.astro";
import HeroSlider from "../components/HeroSlider.astro";
import { getCollection } from "astro:content";
import { SERVICE_ICONS, INDUSTRY_ICONS, PHASE_ICONS } from "../utils/icons";

const stats = [
  { n: "1989",  label: "Founded in Dhaka" },
  { n: "150+",  label: "Engineers and specialists" },
  { n: "50+",   label: "Multi-cloud certified engineers" },
  { n: "200+",  label: "Projects delivered" },
  { n: "70%",   label: "Repeat-client rate" },
  { n: "10+",   label: "Industries served" },
];

const services = (await getCollection("services", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);

const industries = (await getCollection("industries", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);

const featured = (await getCollection("case-studies", ({ data }) => !data.draft && data.featured)).sort(
  (a, b) => a.data.order - b.data.order
);

const phases = [
  { n: "01", name: "Assess", desc: "Current-state discovery, gap analysis, regulatory mapping, technical-debt profile." },
  { n: "02", name: "Design", desc: "Reference architecture, operating model, runbook structure, control mapping." },
  { n: "03", name: "Deploy", desc: "Platform build, application onboarding, security posture, observability." },
  { n: "04", name: "Operate", desc: "Day-2 bring-up: SRE practice, alert hygiene, incident response, capacity and cost." },
  { n: "05", name: "Hand over", desc: "Structured knowledge transfer, runbook walkthroughs, residual-risk register." },
];
---

<Layout>
  <HeroSlider />

  <section class="section" style="background: var(--color-ink); color: #ffffff; padding-top: 3rem; padding-bottom: 3rem; border-bottom: 1px solid #393939;">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem 1rem; align-items: start;" class="stats-grid">
        {stats.map((s) => (
          <div>
            <div style="font-family: var(--font-sans); font-size: 2.25rem; font-weight: 300; letter-spacing: -0.025em; line-height: 1; color: #ffffff;">{s.n}</div>
            <div style="margin-top: 0.55rem; font-size: 0.85rem; color: rgba(255,255,255,0.6); line-height: 1.4;">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Services</span>
        <h2 class="section-title">Four practice areas. One delivery discipline.</h2>
        <p class="section-lede">
          Every engagement is scoped against a documented outcome, sequenced with a structured
          handover, and built around the platforms your operations team will own afterwards.
        </p>
      </div>

      <div class="card-grid card-grid-4">
        {services.map((s) => (
          <a href={`/services/${s.id}/`} class="card">
            <div class="card-icon"><Icon name={SERVICE_ICONS[s.id] ?? "cloud"} size={32} /></div>
            <p class="card-eyebrow">{s.data.eyebrow ?? "Service"}</p>
            <h3 class="card-title">{s.data.title}</h3>
            <p class="card-desc">{s.data.tagline}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Industries</span>
        <h2 class="section-title">Regulated sectors where platform discipline matters.</h2>
        <p class="section-lede">
          We engage where the combination of regulatory pressure, operational expectation,
          and audit-grade engineering rules out generic answers &mdash; and rewards
          specialists who have done the work before.
        </p>
      </div>

      <div class="card-grid card-grid-4">
        {industries.map((i) => (
          <a href={`/industries/${i.id}/`} class="card">
            <div class="card-icon"><Icon name={INDUSTRY_ICONS[i.id] ?? "globe"} size={32} /></div>
            <p class="card-eyebrow">{i.data.eyebrow ?? "Sector"}</p>
            <h3 class="card-title">{i.data.title}</h3>
            <p class="card-desc">{i.data.tagline}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Engagement profiles</span>
        <h2 class="section-title">Representative engagements from our practice.</h2>
        <p class="section-lede">
          Anonymised for client confidentiality. Each profile describes the shape of the
          engagement, the technologies involved, and the outcome delivered.
        </p>
      </div>

      <div class="card-grid card-grid-3">
        {featured.map((c) => (
          <a href={`/case-studies/${c.id}/`} class="card">
            <p class="card-eyebrow">{c.data.sector ?? c.data.customer}</p>
            <h3 class="card-title">{c.data.title}</h3>
            <p class="card-desc">{c.data.summary}</p>
            {c.data.outcome && <p class="card-meta">→ {c.data.outcome}</p>}
          </a>
        ))}
      </div>

      <p style="margin-top: 2rem;">
        <a href="/case-studies/" class="btn btn-secondary">All engagement profiles</a>
      </p>
    </div>
  </section>

  <section class="section" style="background: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">How we deliver</span>
        <h2 class="section-title">Assess. Design. Deploy. Operate. Hand over.</h2>
        <p class="section-lede">
          Every engagement runs through the same five-phase discipline &mdash; sized to scope,
          but never skipped. The endpoint is a platform your team owns, documented well enough
          to outlast staff turnover.
        </p>
      </div>

      <div class="card-grid card-grid-3">
        {phases.map((p) => (
          <div class="card" style="cursor: default;">
            <div class="card-icon"><Icon name={PHASE_ICONS[p.n] ?? "magnifier"} size={32} /></div>
            <p class="card-eyebrow">Phase {p.n}</p>
            <h3 class="card-title">{p.name}</h3>
            <p class="card-desc">{p.desc}</p>
          </div>
        ))}
        <a href="/methodology/" class="card" style="background: var(--color-ink); color: #ffffff;">
          <div class="card-icon" style="color: var(--color-accent-soft);"><Icon name="arrow-right" size={32} /></div>
          <p class="card-eyebrow" style="color: var(--color-accent-soft);">Read more</p>
          <h3 class="card-title" style="color: #ffffff;">Full methodology</h3>
          <p class="card-desc" style="color: rgba(255,255,255,0.7);">
            The detailed view of activities, deliverables, team shape, and contracting model
            for each of the five phases.
          </p>
        </a>
      </div>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container">
      <span class="section-eyebrow">Start a conversation</span>
      <h2 class="section-title">Tell us what you&rsquo;re building.</h2>
      <p class="section-lede">
        Send us a short note. We&rsquo;ll write back with a concrete first-two-weeks scope and a
        definition of done for the engagement.
      </p>
      <div class="section-cta-actions">
        <a href="/contact/" class="btn btn-primary">Contact us</a>
        <a href="/about/" class="btn btn-dark">About CompTech</a>
      </div>
    </div>
  </section>
</Layout>
