    capabilities: ["SLES", "Rancher", "Harvester", "NeuVector"],
  },
  {
    name: "Cisco",
    category: "Networking / Security",
    description: "Nexus 9000 data-centre fabrics, ACI, Catalyst SD-WAN, ISE, Secure Firewall, Cisco XDR, Secure Endpoint, Duo, Secure Access (SSE), Splunk — the network and security backbone of most BFSI and telecom engagements.",
    capabilities: ["Nexus 9000 / NX-OS", "ACI / APIC", "Catalyst SD-WAN", "ISE", "Secure Firewall (FTDv/FMC)", "Cisco XDR", "Duo", "Splunk"],
    status: "Operating partner",
  },
  {
    name: "Palo Alto Networks",
    category: "Networking / Security",
    logo: "/images/partners/pa.png",
    description: "Next-gen firewalls, Prisma Cloud, Prisma Access (SASE), Cortex XDR — used where BFSI and government engagements require Palo-Alto-grade controls.",
    capabilities: ["NGFW", "Prisma Cloud", "Prisma Access", "Cortex XDR"],
  },
  {
    name: "Check Point",
    category: "Networking / Security",
    logo: "/images/partners/checkpoint.png",
    description: "Quantum firewalls, Harmony endpoint, CloudGuard — security stack for enterprise perimeters and cloud workloads.",
    capabilities: ["Quantum", "Harmony", "CloudGuard", "Infinity"],
  },
  {
    name: "F5",
    category: "Networking / Security",
    logo: "/images/partners/f5.jpeg",
    description: "BIG-IP, NGINX, Distributed Cloud — application delivery and security across regulated workloads.",
    capabilities: ["BIG-IP", "NGINX", "Distributed Cloud", "WAAP"],
  },
  {
    name: "HashiCorp",
    category: "Platform / Security",
    description: "Vault for credential custody, Terraform for infrastructure as code, Consul where service discovery is needed — Vault sits at the credential-root of every platform we deploy.",
