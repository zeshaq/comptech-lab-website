---
import Layout from "../../layouts/Layout.astro";
import Icon from "../../components/Icon.astro";
import DotGrid from "../../components/DotGrid.astro";
import HeroBackground from "../../components/HeroBackground.astro";
import { PARTNER_CATEGORY_ICONS } from "../../utils/icons";

interface Partner {
  name: string;
  category: string;
  description: string;
  capabilities: string[];
  status?: string;
  logo?: string;
}

const partners: Partner[] = [
