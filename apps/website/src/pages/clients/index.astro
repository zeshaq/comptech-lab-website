---
import Layout from "../../layouts/Layout.astro";
import HeroBackground from "../../components/HeroBackground.astro";

interface Client {
  name: string;
  logo: string;
  sector: string;
}

const clients: Client[] = [
  // Government & defense
  { name: "Bangladesh Bank",                      logo: "/images/clients/bb.png",        sector: "Government & central authorities" },
  { name: "Bangladesh Border Guard (BGB)",        logo: "/images/clients/bgb.png",       sector: "Government & central authorities" },
  { name: "Bangladesh Bureau of Statistics",      logo: "/images/clients/bbs.png",       sector: "Government & central authorities" },
  { name: "Bangladesh Rice Research Institute",   logo: "/images/clients/brri.png",      sector: "Government & central authorities" },
  { name: "Bangladesh Computer Council",          logo: "/images/clients/bcc.svg",       sector: "Government & central authorities" },
  // Banking & financial services
  { name: "Janata Bank",                          logo: "/images/clients/jb.svg",        sector: "Banking & financial services" },
  { name: "First Security Islami Bank",           logo: "/images/clients/fsibl.png",     sector: "Banking & financial services" },
  { name: "Eastern Bank Limited",                 logo: "/images/clients/ebl.png",       sector: "Banking & financial services" },
  { name: "Pubali Bank",                          logo: "/images/clients/pbl.jpg",       sector: "Banking & financial services" },
  { name: "BRAC Bank",                            logo: "/images/clients/brac-bank.svg", sector: "Banking & financial services" },
  { name: "City Bank",                            logo: "/images/clients/city-bank.png", sector: "Banking & financial services" },
  { name: "Modhumoti Bank",                       logo: "/images/clients/modhumoti.png", sector: "Banking & financial services" },
  { name: "Shimanto Bank",                        logo: "/images/clients/shimanto.png",  sector: "Banking & financial services" },
  { name: "EXIM Bank",                            logo: "/images/clients/exim.png",      sector: "Banking & financial services" },
  // Corporate
  { name: "British American Tobacco (BAT)",       logo: "/images/clients/bat.png",       sector: "Corporate & manufacturing" },
  { name: "Unilever",                             logo: "/images/clients/unilever.png",  sector: "Corporate & manufacturing" },
  // Development & humanitarian
  { name: "USAID",                                logo: "/images/clients/usaid.jpg",     sector: "Development & humanitarian" },
  { name: "UNDP",                                 logo: "/images/clients/undp.png",      sector: "Development & humanitarian" },
  { name: "World Health Organization",            logo: "/images/clients/who.png",       sector: "Development & humanitarian" },
  { name: "UK Aid",                               logo: "/images/clients/ukaid.png",     sector: "Development & humanitarian" },
  { name: "IFES",                                 logo: "/images/clients/ifes.png",      sector: "Development & humanitarian" },
  { name: "The Hunger Project",                   logo: "/images/clients/thp.png",       sector: "Development & humanitarian" },
  { name: "The Asia Foundation",                  logo: "/images/clients/taf.png",       sector: "Development & humanitarian" },
  // Healthcare & education
  { name: "BIRDEM Hospital",                      logo: "/images/clients/birdem.png",    sector: "Healthcare & education" },
  { name: "BUET",                                 logo: "/images/clients/buet.png",      sector: "Healthcare & education" },
  { name: "University of Dhaka",                  logo: "/images/clients/du.png",        sector: "Healthcare & education" },
  { name: "Bangladesh Open University",           logo: "/images/clients/bou.png",       sector: "Healthcare & education" },
  { name: "BdREN",                                logo: "/images/clients/bdren.png",     sector: "Healthcare & education" },
];

const bySector = clients.reduce<Record<string, Client[]>>((acc, c) => {
  (acc[c.sector] ??= []).push(c);
  return acc;
}, {});

const sectorOrder = [
  "Banking & financial services",
  "Government & central authorities",
  "Development & humanitarian",
  "Healthcare & education",
  "Corporate & manufacturing",
];
---

<Layout
  title="Clients — CompTech"
  description="Three decades of trusted client relationships across banking, government, development, healthcare, education, and corporate sectors in Bangladesh and internationally."
>
  <section class="hero">
    <HeroBackground variant="hexagon" />
    <div class="container">
      <span class="hero-eyebrow">Clients</span>
      <h1 class="hero-title">Three decades. 70% repeat clients.</h1>
      <p class="hero-lede">
        Selected clients across banking, government, development, healthcare, education,
        and corporate sectors. References available under NDA on request.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {sectorOrder.filter((s) => bySector[s]?.length).map((sector) => (
        <div style="margin-bottom: 3.5rem;">
          <p class="section-eyebrow">{sector}</p>
          <h2 style="font-size: 1.5rem; font-weight: 400; margin: 0.35rem 0 1.5rem; letter-spacing: -0.01em;">
            {bySector[sector].length} clients
          </h2>
          <div class="client-grid">
            {bySector[sector].map((c) => (
              <div class="client-tile" title={c.name}>
                <img src={c.logo} alt={c.name} loading="lazy" />
                <span class="client-tile-name">{c.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}

      <p style="margin-top: 2.5rem; padding: 1.25rem 1.5rem; background: var(--color-surface); border-left: 3px solid var(--color-accent); font-size: 0.92rem; color: var(--color-muted); line-height: 1.55;">
        <strong style="color: var(--color-ink);">A note on client logos:</strong>
        client names and logos are shown to illustrate the type of organisation we work with.
        Specific project details, references, and case studies are shared under NDA during
        engagement scoping &mdash; see <a href="/case-studies/" style="color: var(--color-accent);">engagement profiles</a>
        for the anonymised public view of our work.
      </p>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container">
      <span class="section-eyebrow">Start a conversation</span>
      <h2 class="section-title">Join the list.</h2>
      <p class="section-lede">
        Send us a short note describing what you&rsquo;re building. We&rsquo;ll write back with
        a concrete first-two-weeks scope.
      </p>
      <div class="section-cta-actions">
        <a href="/contact/" class="btn btn-primary">Contact us</a>
        <a href="/case-studies/" class="btn btn-dark">Engagement profiles</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .client-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }
  @media (min-width: 640px) { .client-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .client-grid { grid-template-columns: repeat(5, 1fr); } }

  .client-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 1rem 1.25rem;
    min-height: 140px;
    background: var(--color-canvas);
    text-align: center;
    transition: background 0.15s ease;
  }
  .client-tile:hover { background: var(--color-surface); }

  .client-tile img {
    max-height: 60px;
    max-width: 100%;
    object-fit: contain;
    filter: grayscale(0.2);
  }

  .client-tile-name {
    margin-top: 0.75rem;
    font-size: 0.75rem;
    color: var(--color-muted);
    line-height: 1.3;
  }
</style>
